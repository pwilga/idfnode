# Usage: -DDEVICE_PROFILE=p4dev -DDEVICE_PROFILE_VARIANT=eth
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

CONFIG_VFS_LITTLEFS_ENABLED=y

# Ethernet uplink (M5Stack Unit PoE-P4)
CONFIG_ENABLE_SUPERVISOR_INET_ETHERNET=y

# Ethernet hardware backend: ESP32-P4 internal EMAC + IP101GRI PHY over RMII.
# Data-plane pins follow ESP32-P4 IO_MUX defaults; only PHY addr + reset are board-specific.
CONFIG_ETHERNET_ESP_EMAC=y
CONFIG_ETHERNET_PHY_IP101=y
CONFIG_ETHERNET_PHY_ADDR=1
CONFIG_ETHERNET_PHY_RST_GPIO=51
