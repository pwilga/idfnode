# Usage: -DDEVICE_PROFILE=atom -DDEVICE_PROFILE_VARIANT=obr
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# LittleFS — general purpose storage (certs, config, app data).
# CONFIG_VFS_LITTLEFS_ENABLED=y
# SPIFFS — web_storage partition for Thread BR web GUI assets.
CONFIG_VFS_SPIFFS_ENABLED=y

# CONFIG_ENABLE_SUPERVISOR_INET=y #wifi
CONFIG_ENABLE_SUPERVISOR_INET_ETHERNET=y
# Ethernet Hardware Backend
CONFIG_ETHERNET_W5500=y

CONFIG_ENABLE_SUPERVISOR_THREAD_BORDER_ROUTER=y
# eventfd (required by OpenThread)
CONFIG_VFS_EVENTFD_MAX_FDS=5

CONFIG_THREAD_BORDER_ROUTER_WEB=y
CONFIG_OPENTHREAD_COMMISSIONER=y
CONFIG_OPENTHREAD_JOINER=y

# OpenThread (required for Thread BR adapter)
CONFIG_OPENTHREAD_ENABLED=y
CONFIG_OPENTHREAD_BORDER_ROUTER=y
CONFIG_OPENTHREAD_RADIO_SPINEL_UART=y
CONFIG_OPENTHREAD_TASK_SIZE=8192
CONFIG_OPENTHREAD_CLI=y
CONFIG_OPENTHREAD_RCP_COMMAND=y
CONFIG_OPENTHREAD_DNS64_CLIENT=y

# Uncomment for TCP OTA (push-based) — required to buffer large in-flight data over Thread
# CONFIG_OPENTHREAD_NUM_MESSAGE_BUFFERS=256

# LWIP IPv6 forwarding (required for Border Router)
CONFIG_LWIP_MULTICAST_PING=y
CONFIG_LWIP_NETIF_STATUS_CALLBACK=y
CONFIG_LWIP_IPV6_FORWARD=y
CONFIG_LWIP_IPV6_NUM_ADDRESSES=12
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y
CONFIG_LWIP_HOOK_IP6_INPUT_CUSTOM=y
CONFIG_LWIP_IPV6_AUTOCONFIG=y
CONFIG_LWIP_HOOK_IP6_SELECT_SRC_ADDR_CUSTOM=y
CONFIG_LWIP_FORCE_ROUTER_FORWARDING=y

# mbedTLS for OpenThread
CONFIG_MBEDTLS_ECJPAKE_C=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECJPAKE=y
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_CMAC_C=y


# WiFi minimal config for ESP-NOW only (no WiFi AP connection needed on atom)
# Default values are tuned for full WiFi stack and waste 50-70KB RAM.
# atom uses W5500 Ethernet for network - WiFi radio is ESP-NOW only.
# CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=2
# CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=4
# CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=2
# CONFIG_ESP_WIFI_MGMT_SBUF_NUM=4
# CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=n
# CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=n
# CONFIG_ESP_WIFI_NVS_ENABLED=n
# CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n
# CONFIG_ESP_WIFI_ENTERPRISE_SUPPORT=n
# CONFIG_ESP_WIFI_ENABLE_WPA3_SAE=n
# CONFIG_ESP_WIFI_ENABLE_SAE_H2E=n
# CONFIG_ESP_WIFI_ENABLE_SAE_PK=n
# CONFIG_ESP_WIFI_ESPNOW_MAX_ENCRYPT_NUM=0
# CONFIG_ESP_WIFI_DYNAMIC_RX_MGMT_BUF=y
# CONFIG_ESP_WIFI_RX_MGMT_BUF_NUM_DEF=2
# CONFIG_ESP_WIFI_STA_DISCONNECTED_PM_ENABLE=n
