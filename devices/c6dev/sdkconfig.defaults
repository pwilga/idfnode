CONFIG_ENABLE_SUPERVISOR_DEBUG=y
CONFIG_ENABLE_SUPERVISOR_THREAD_DEVICE=y
CONFIG_VFS_LITTLEFS_ENABLED=y

# Status LED (GPIO8 on C6 DevKit — RGB WS2812B)
# CONFIG_BOARD_STATUS_LED_GPIO=8

# eventfd required by OpenThread
CONFIG_VFS_EVENTFD_MAX_FDS=5

# OpenThread common
CONFIG_OPENTHREAD_ENABLED=y
CONFIG_OPENTHREAD_CLI=y
CONFIG_OPENTHREAD_RADIO_NATIVE=y
CONFIG_IEEE802154_ENABLED=y
CONFIG_OPENTHREAD_DNS64_CLIENT=y
# Needed for HTTP — large files cause NoBufs over 6LoWPAN (default 65).
# Comment out if not using HTTP to save ~8KB RAM.
CONFIG_OPENTHREAD_NUM_MESSAGE_BUFFERS=128

# mbedTLS for OpenThread
CONFIG_MBEDTLS_ECJPAKE_C=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECJPAKE=y
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_CMAC_C=y

# LWIP for Thread netif
CONFIG_LWIP_IPV6_NUM_ADDRESSES=8
CONFIG_LWIP_HOOK_IP6_SELECT_SRC_ADDR_CUSTOM=y
CONFIG_LWIP_MULTICAST_PING=y
# NAT64 for lwIP sockets (MQTT/SNTP/esp-tls) — lets lwip_hook_dns_external_resolve synthesize NAT64
CONFIG_LWIP_HOOK_DNS_EXT_RESOLVE_CUSTOM=y
