CONFIG_ENABLE_SUPERVISOR_BUTTON=y
CONFIG_ENABLE_SUPERVISOR_DEBUG=y
# CONFIG_ENABLE_SUPERVISOR_DS18B20=y
# CONFIG_ENABLE_SUPERVISOR_ESP_NOW_RX=y
# CONFIG_ENABLE_SUPERVISOR_INET=y
CONFIG_ENABLE_SUPERVISOR_INET_MESH=y
# CONFIG_ENABLE_SUPERVISOR_LED=y
# CONFIG_ENABLE_SUPERVISOR_RF433=y
# CONFIG_ENABLE_SUPERVISOR_ZIGBEE=y
CONFIG_ENABLE_SUPERVISOR_NEOPIXEL=y

CONFIG_BUTTON_GPIO_LIST="41:0"

# System event task stack size (default 2304 too small for MQTT/HA init in event handlers)
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=3072

CONFIG_TCP_OTA_TASK_STACK_SIZE=5120

# --- ESP-LITE-MESH ---
CONFIG_MESH_LITE_ENABLE=y
CONFIG_MESH_LITE_NODE_INFO_REPORT=y
CONFIG_DEVICE_CATEGORY="sensor"

# --- ESP-LITE-MESH --- # --- FREERTOS / STACK TUNING ---
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=6144

# --- ESP-LITE-MESH --- # --- BRIDGE ---
CONFIG_BRIDGE_ETHERNET_NETIF_ENABLE=n
CONFIG_BRIDGE_SOFTAP_SSID_END_WITH_THE_MAC=y
